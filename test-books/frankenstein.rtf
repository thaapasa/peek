{\*\bkmkstart h.tgr9gfz3rq1x}{\*\bkmkend h.tgr9gfz3rq1x}Chapter 1}
\par \pard\plain \s0\sl276\slmult1\ql\widctlpar\hyphpar0\faauto\sb0\sa0\ltrpar\kerning1\strike0\ulc0\cf1\rtlch\af7\afs22\alang1081\ai0\ab0\ltrch\hich\af4\afs22\alang2057\ai0\aulnone\ab0\dbch\af7\langfe2052\loch\f4\fs22\lang2057\i0\ulnone\b0\sl276\slmult1\qj\fi0\li0\lin0\ri0\rin0\brdrt\brdrnone\brdrl\brdrnone\brdrb\brdrnone\brdrr\brdrnone

